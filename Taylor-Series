clear all;clc;close all;
x=linspace(0,pi,20); 

y=cos(x);

y1=ones(1,20);

y3=1-x.^2/factorial(2);

y5=1-x.^2/factorial(2)+x.^4/factorial(4);

figure (1)

plot(x,y,'-')
hold on
plot( x,y1,'x')
hold on
plot(x, y3,'--')
hold on
plot(x,y5,'-.');

axis([0,4,-2,2]);

legend('gercek','1 terimli', '3 terimli', '5 terimli');

xlabel('x');ylabel('y');

grid
